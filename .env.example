# Copie este arquivo para .env e preencha os valores.
# .env nunca entra no git (já coberto pelo .gitignore).

# Token de API do Sketchfab. Pegue em: https://sketchfab.com/settings/password
# Obrigatório em produção; opcional quando DRY_RUN=true.
SKETCHFAB_TOKEN=

# Base da URL do viewer. Default já aponta para produção.
VIEWER_BASE=https://biodesignlab.com.br/case/

# ---- Cloudflare R2 (Sprint 2) ----

# Account ID da Cloudflare. Visível no painel R2 > Account Details.
# Usado para montar o endpoint S3: https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ACCOUNT_ID=

# Access Key + Secret do token "mesh-processor" (R2 > Manage R2 API Tokens).
# Escopo mínimo: Leitura/gravação para objeto, apenas no bucket clinical-3d.
# Obrigatórios em produção; opcionais quando DRY_RUN=true.
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Bucket onde os GLBs vão parar. Default: clinical-3d.
R2_BUCKET=clinical-3d

# Quando true, não chama as APIs externas (Sketchfab nem R2) — retorna respostas conhecidas.
# Use em dev/CI para conservar slots do plano Basic (10/mês) e poupar ops R2.
DRY_RUN=false
